modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python Telethon Engine"

[[workflows.workflow]]
name = "Python Telethon Engine"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 9000/tcp 2>/dev/null; sleep 1; uv run python python-backend/main.py"
waitForPort = 9000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 4200

[[ports]]
localPort = 8090
externalPort = 3003

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 18081
externalPort = 5000

[[ports]]
localPort = 18082
externalPort = 5173

[[ports]]
localPort = 23183
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "openssl", "postgresql"]

[userenv]

