modules = ["nodejs-24", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python Telethon Engine"

[[workflows.workflow]]
name = "Python Telethon Engine"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv run python python-backend/main.py"
waitForPort = 8090

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8090
externalPort = 3003

[[ports]]
localPort = 23183
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "openssl", "postgresql"]

[userenv]

[userenv.shared]
ADMIN_EMAIL = "simixsupport@gmail.com"
ADMIN_PASSWORD_HASH = "$2b$12$wQXXgt5GLTFWyvrlLBPPXOvrZm1n9IIRqCsLafZISpOmLFgpnzU6S"
ADMIN_NAME = "Nexus AI Admin"
